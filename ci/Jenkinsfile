pipeline {
    agent any

    environment {
        COMPOSE_FILE = 'docker/docker-compose.yml'
        APP_URL      = 'http://localhost:8081'

        DB_HOST      = 'db'
        DB_PORT      = '3306'
        DB_NAME      = 'demo_app'
        DB_USER      = 'demo_user'
        DB_PASSWORD  = 'Train123#demo'

    stages {
        stage('Checkout') {
            steps {
                checkout scm
            }
        }

        stage('Lint / Validate') {
            steps {
                sh '''
                  set -e
                  echo "Validating required env vars..."
                  [ -n "$DB_HOST" ]
                  [ -n "$DB_NAME" ]
                  [ -n "$DB_USER" ]
                  [ -n "$DB_PASSWORD" ]

                  echo "PHP syntax check..."
                  find app -name "*.php" -print0 | xargs -0 -n1 php -l
                '''
            }
        }

        stage('Docker Build') {
            steps {
                sh 'docker compose -f docker/docker-compose.yml build'
            }
        }

        stage('Smoke Test') {
            steps {
                sh '''
                  docker compose -f docker/docker-compose.yml up -d
                  sleep 20
                  ./scripts/test_smoke.sh
                '''
            }
            post {
                always {
                    sh 'docker compose -f docker/docker-compose.yml down'
                }
            }
        }
    }
}
